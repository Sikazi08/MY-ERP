auto-install-peers=false
strict-peer-dependencies=false

# Autoriser les scripts de build pour ces packages (requis par pnpm v10+)
# esbuild: nécessaire pour Vite et le bundling
# @swc/core: compilation TypeScript/JavaScript
# msw: Mock Service Worker
# unrs-resolver: résolveur de modules
only-built-dependencies[]=esbuild
only-built-dependencies[]=@swc/core
only-built-dependencies[]=msw
only-built-dependencies[]=unrs-resolver
